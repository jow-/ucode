{%
import * as ffi from 'ffi';

ffi.cdef('struct point { int x; int y; }; struct polyline { struct point pts[3]; int count; };');
let poly = ffi.ctype('struct polyline', {
    pts: [
        {x: 1, y: 2},
        {x: 3, y: 4},
        {x: 5, y: 6}
    ],
    count: 3
});

let pts = poly.get('pts');
print("pts[0]: ", pts[0].x, " ", pts[0].y, " count: ", poly.get('count'), "\n");
-- End --

-- Expect stdout --
pts[0]: 1 2 count: 3
